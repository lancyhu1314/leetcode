<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="PRODUCTMAPPING">

    <insert id="insert" parameterType="com.suning.fab.faibfp.bean.ProductMapping">
        insert into PRODUCTMAPPING(routeId,receiptNo,productcode,routetype,createtime,updatetime)
            values (#{routeId},#{receiptNo},#{productCode},#{routeType},CURRENT_TIMESTAMP,CURRENT_TIMESTAMP)
    </insert>

    <select id="selectByKey" parameterType="map" resultType="com.suning.fab.faibfp.bean.ProductMapping">
        select receiptNo,productcode,routetype
        from PRODUCTMAPPING
        where routeid = #{routeId}
    </select>

    <update id="update" parameterType="map">
        update PRODUCTMAPPING
        set receiptNo = #{receiptNo},
            productcode = #{productCode},
            routetype = #{routeType},
            updatetime = CURRENT_TIMESTAMP
        where routeid = #{routeId}
    </update>

</mapper>