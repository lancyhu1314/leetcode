<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="PRODUCTMAPPING">

    <insert id="insert" parameterType="com.suning.fab.faibfp.bean.ProductMapping">
        insert into PRODUCTMAPPING(routeId,receiptNo,productcode,dataflag,createtime,updatetime)
            values (#{routeId},#{receiptNo},#{productCode},#{dataFlag},CURRENT_TIMESTAMP,CURRENT_TIMESTAMP)
    </insert>

    <select id="selectByKey" parameterType="map" resultType="com.suning.fab.faibfp.bean.ProductMapping">
        select receiptNo,productcode,dataflag
        from PRODUCTMAPPING
        where routeid = #{routeId}
    </select>


</mapper>